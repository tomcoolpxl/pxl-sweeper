{
  "name": "pxl-sweeper",
  "version": "1.0.0",
  "description": "A modern, high-contrast Minesweeper clone.",
  "scripts": {
    "start": "serve . -p 8080",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/js/*.js",
    "build": "mkdir -p dist && cp -r src index.html dist/"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "serve": "^14.2.4",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
